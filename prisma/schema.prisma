generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String?
  role          String         @default("USER")
  phone         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  notifications Notification[]
  wishlistItems WishlistItem[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model City {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String?  @unique
  banner      String?
  faqQuestion String?
  faqAnswer   String?
  createdAt   DateTime @default(now())
  cars        Car[]
  tours       Tour[]
  villas      Villa[]
}

model Car {
  id              String         @id @default(cuid())
  make            String
  model           String
  category        String
  fuelType        String
  transmission    String
  seatingCapacity Int
  image           String
  availability    Boolean        @default(true)
  cityId          String?
  content         String?        @default("")
  serviceTypes    String[]       @default(["SELF_DRIVE"])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  bookings        Booking[]
  city            City?          @relation(fields: [cityId], references: [id])
  packages        CarPackage[]
  wishlistItems   WishlistItem[]
}

model CarPackage {
  id                 String   @id @default(cuid())
  carId              String
  type               String
  name               String
  basePrice          Float
  deposit            Float    @default(0)
  limitValue         Int?
  extraChargePerUnit Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  car                Car      @relation(fields: [carId], references: [id])
}

model Tour {
  id            String         @id @default(cuid())
  title         String
  description   String
  adultPrice    Float
  childPrice    Float
  duration      Int
  image         String
  gallery       String
  itinerary     String
  included      String
  excluded      String
  cityId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  city          City?          @relation(fields: [cityId], references: [id])
  wishlistItems WishlistItem[]
}

model Villa {
  id            String         @id @default(cuid())
  name          String
  description   String
  location      String
  startingPrice Float
  image         String
  gallery       String
  amenities     String
  roomTypes     String
  occupancy     Int
  cityId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  city          City?          @relation(fields: [cityId], references: [id])
  wishlistItems WishlistItem[]
}

model Booking {
  id                String   @id @default(cuid())
  userId            String
  type              String
  carId             String?
  tourId            String?
  villaId           String?
  startDate         DateTime
  endDate           DateTime
  totalAmount       Float
  advancePaid       Float
  remainingAmount   Float
  depositAmount     Float    @default(0)
  status            String   @default("PENDING")
  depositStatus     String   @default("PENDING")
  driverName        String?
  driverEmail       String?
  driverPhone       String?
  driverDob         String?
  aadharFile        String?
  dlFile            String?
  specialRequests   String?
  rejectionReason   String?
  razorpayPaymentId String?
  refundStatus      String   @default("NONE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  car               Car?     @relation(fields: [carId], references: [id])
  tour              Tour?    @relation(fields: [tourId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
  villa             Villa?   @relation(fields: [villaId], references: [id])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  type      String
  carId     String?
  tourId    String?
  villaId   String?
  createdAt DateTime @default(now())
  car       Car?     @relation(fields: [carId], references: [id])
  tour      Tour?    @relation(fields: [tourId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  villa     Villa?   @relation(fields: [villaId], references: [id])
}

model PricingRule {
  id                 String   @id @default(cuid())
  weekendMarkup      Float    @default(15)
  festivalSurge      Float    @default(30)
  dynamicSurgeActive Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model GlobalPackageTier {
  id              String   @id @default(cuid())
  name            String
  type            String
  basePricingInfo String
  limitInfo       String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  discountValue Float
  discountType  String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  category  String
  content   String
  isDraft   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AboutPage {
  id        String   @id @default("singleton")
  title     String   @default("About GoRidez")
  subtitle  String   @default("Premium Car Rentals & Excursions in Rajasthan")
  content   String
  imageUrl  String?
  updatedAt DateTime @updatedAt
}

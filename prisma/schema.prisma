generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String?
  role          String         @default("USER") // USER or ADMIN
  phone         String?
  bookings      Booking[]
  wishlistItems WishlistItem[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model City {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String?  @unique
  banner      String?
  faqQuestion String?
  faqAnswer   String?
  cars        Car[]
  tours       Tour[]
  villas      Villa[]
  createdAt   DateTime @default(now())
}

model Car {
  id              String         @id @default(cuid())
  make            String
  model           String
  category        String
  fuelType        String
  transmission    String
  seatingCapacity Int
  image           String
  availability    Boolean        @default(true)
  cityId          String?
  city            City?          @relation(fields: [cityId], references: [id])
  packages        CarPackage[]
  bookings        Booking[]
  wishlistItems   WishlistItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model CarPackage {
  id                 String   @id @default(cuid())
  carId              String
  car                Car      @relation(fields: [carId], references: [id])
  type               String // "KM", "HOUR", "TRANSFER"
  name               String // e.g. "120 KM Package", "4 Hours", "Airport Pickup"
  basePrice          Float
  deposit            Float    @default(0)
  limitValue         Int? // e.g. 120 (for km) or 4 (for hours)
  extraChargePerUnit Float? // e.g. 10 (for extra km or hour)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Tour {
  id            String         @id @default(cuid())
  title         String
  description   String
  adultPrice    Float
  childPrice    Float
  duration      Int // in days
  image         String
  gallery       String // JSON string of image URLs
  itinerary     String // JSON string of daily itinerary
  included      String // JSON array of strings
  excluded      String // JSON array of strings
  cityId        String?
  city          City?          @relation(fields: [cityId], references: [id])
  bookings      Booking[]
  wishlistItems WishlistItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Villa {
  id            String         @id @default(cuid())
  name          String
  description   String
  location      String
  startingPrice Float
  image         String
  gallery       String // JSON array of image URLs
  amenities     String // JSON array of amenities
  roomTypes     String // JSON array of room types
  occupancy     Int
  cityId        String?
  city          City?          @relation(fields: [cityId], references: [id])
  bookings      Booking[]
  wishlistItems WishlistItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Booking {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  type   String // "CAR", "TOUR", "VILLA"

  carId String?
  car   Car?    @relation(fields: [carId], references: [id])

  tourId String?
  tour   Tour?   @relation(fields: [tourId], references: [id])

  villaId String?
  villa   Villa?  @relation(fields: [villaId], references: [id])

  startDate DateTime
  endDate   DateTime

  totalAmount     Float
  advancePaid     Float
  remainingAmount Float
  depositAmount   Float @default(0)

  status        String @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  depositStatus String @default("PENDING") // PENDING, PAID, REFUNDED, ADJUSTED

  driverName      String?
  driverEmail     String?
  driverPhone     String?
  driverDob       String?
  aadharFile      String?
  dlFile          String?
  specialRequests String?

  rejectionReason   String?
  razorpayPaymentId String?
  refundStatus      String  @default("NONE") // NONE, PENDING, PROCESSED, FAILED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  type   String // "CAR", "TOUR", "VILLA"

  carId String?
  car   Car?    @relation(fields: [carId], references: [id])

  tourId String?
  tour   Tour?   @relation(fields: [tourId], references: [id])

  villaId String?
  villa   Villa?  @relation(fields: [villaId], references: [id])

  createdAt DateTime @default(now())
}

model PricingRule {
  id                 String   @id @default(cuid())
  weekendMarkup      Float    @default(15)
  festivalSurge      Float    @default(30)
  dynamicSurgeActive Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model GlobalPackageTier {
  id              String   @id @default(cuid())
  name            String
  type            String // "HOURS", "KM", "CUSTOM"
  basePricingInfo String
  limitInfo       String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  discountValue Float
  discountType  String // "PERCENTAGE" or "FLAT"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  category  String
  content   String // Store raw HTML from Rich Text Editor
  isDraft   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AboutPage {
  id        String   @id @default("singleton")
  title     String   @default("About GoRidez")
  subtitle  String   @default("Premium Car Rentals & Excursions in Rajasthan")
  content   String // Store raw HTML from content editor
  imageUrl  String? // Optional banner image URL
  updatedAt DateTime @updatedAt
}

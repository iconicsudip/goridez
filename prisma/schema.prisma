generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String?
  role          String         @default("USER")
  phone         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  notifications Notification[]
  wishlistItems WishlistItem[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model City {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String?  @unique
  banner      String?
  faqQuestion String?
  faqAnswer   String?
  airportName String?
  createdAt       DateTime @default(now())
  cars            Car[]
  tours           Tour[]
  villas          Villa[]
  deliveryCharges DeliveryCharge[]
  airportZones    AirportZone[]
}

model AirportZone {
  id         String   @id @default(cuid())
  cityId     String
  name       String
  localities String[] @default([])
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  city       City             @relation(fields: [cityId], references: [id], onDelete: Cascade)
  fares      AirportZoneFare[]

  @@unique([cityId, name])
}

model AirportZoneFare {
  id                 String   @id @default(cuid())
  zoneId             String
  vehicleCategory    String
  pickupPrice        Float    @default(0)
  dropPrice          Float    @default(0)
  waitChargePer30Min Float    @default(0)
  nightFee           Float    @default(0)
  meetAndGreet       Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  zone               AirportZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, vehicleCategory])
}

model Car {
  id              String         @id @default(cuid())
  make            String
  model           String
  category        String
  fuelType        String
  transmission    String
  seatingCapacity Int
  image           String
  gallery         String         @default("[]")
  availability    Boolean        @default(true)
  cityId          String?
  content         String?        @default("")
  serviceTypes    String[]       @default(["SELF_DRIVE"])
  features        String[]       @default([])
  extraHourCharge      Float?
  nightCharge          Float?
  nightChargeStart     String?  @default("22:00")
  nightChargeEnd       String?  @default("06:00")
  driverAllowanceDay   Float?
  driverAllowanceOut   Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  bookings        Booking[]
  city            City?          @relation(fields: [cityId], references: [id])
  packages        CarPackage[]
  wishlistItems   WishlistItem[]
}

model CarPackage {
  id                 String   @id @default(cuid())
  carId              String
  type               String
  name               String
  basePrice          Float
  deposit            Float    @default(0)
  limitValue         Int?
  extraChargePerUnit Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  car                Car      @relation(fields: [carId], references: [id])
}

model Tour {
  id            String         @id @default(cuid())
  title         String
  description   String
  adultPrice    Float
  childPrice    Float
  duration      Int
  image         String
  gallery       String
  itinerary     String
  included      String
  excluded      String
  cityId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  city          City?          @relation(fields: [cityId], references: [id])
  wishlistItems WishlistItem[]
}

model Villa {
  id            String         @id @default(cuid())
  name          String
  description   String
  location      String
  startingPrice Float
  image         String
  gallery       String
  amenities     String
  roomTypes     String
  occupancy     Int
  cityId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  bookings      Booking[]
  city          City?          @relation(fields: [cityId], references: [id])
  wishlistItems WishlistItem[]
}

model Booking {
  id                String   @id @default(cuid())
  userId            String
  type              String
  carId             String?
  tourId            String?
  villaId           String?
  startDate         DateTime
  endDate           DateTime
  totalAmount       Float
  advancePaid       Float
  remainingAmount   Float
  depositAmount     Float    @default(0)
  status            String   @default("PENDING")
  depositStatus     String   @default("PENDING")
  driverName        String?
  driverEmail       String?
  driverPhone       String?
  driverDob         String?
  pickupStation     String?
  dropStation       String?
  deliveryFee       Float?   @default(0)
  aadharFile        String?
  dlFile            String?
  specialRequests   String?
  rejectionReason   String?
  razorpayPaymentId String?
  refundStatus      String   @default("NONE")
  serviceSubtype    String?  // e.g. "SELF_DRIVE", "CHAUFFEUR", "ONE_WAY", "ROUND_TRIP", "AIRPORT_TRANSFER"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  car               Car?     @relation(fields: [carId], references: [id])
  tour              Tour?    @relation(fields: [tourId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
  villa             Villa?   @relation(fields: [villaId], references: [id])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  type      String
  carId     String?
  tourId    String?
  villaId   String?
  createdAt DateTime @default(now())
  car       Car?     @relation(fields: [carId], references: [id])
  tour      Tour?    @relation(fields: [tourId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  villa     Villa?   @relation(fields: [villaId], references: [id])
}

model PricingRule {
  id                 String   @id @default(cuid())
  weekendMarkup      Float    @default(15)
  festivalSurge      Float    @default(30)
  dynamicSurgeActive Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model GlobalPackageTier {
  id              String   @id @default(cuid())
  name            String
  type            String
  basePricingInfo String
  limitInfo       String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  discountValue Float
  discountType  String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  category  String
  content   String
  isDraft   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AboutPage {
  id        String   @id @default("singleton")
  title     String   @default("About GoRidez")
  subtitle  String   @default("Premium Car Rentals & Excursions in Rajasthan")
  content   String
  imageUrl  String?
  updatedAt DateTime @updatedAt
}

model LegalPage {
  id        String   @id // 'privacy' | 'terms' | 'contact'
  title     String
  content   String
  imageUrl  String?
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model InstagramReel {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  category  String   @default("Customer Reels")
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model DeliveryCharge {
  id              String   @id @default(cuid())
  cityId          String
  category        String
  airportPickup   Float
  airportDrop     Float
  railwayPickup   Float
  railwayDrop     Float
  lateNightStart  String   @default("22:00")
  lateNightEnd    String   @default("06:00")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  city            City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, category])
}

model TaxiFareSetting {
  id               String   @id @default(cuid())
  vehicleCategory  String   @unique // e.g., "Sedan", "SUV", "Luxury"
  
  // Airport Transfer Settings
  airportBaseFare  Float    @default(0)
  airportRatePerKm Float    @default(15)
  airportMinFare   Float    @default(300)
  
  // Round Trip Settings
  roundTripRatePerKm Float  @default(13)
  roundTripMinKmPerDay Int  @default(250)
  driverAllowancePerDay Float @default(350)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model HomePage {
  id                     String   @id @default("singleton")
  heroBadge              String   @default("✦ PREMIUM TRANSPORTATION")
  heroTitleLine1         String   @default("EXPLORE RAJASTHAN")
  heroTitleLine2         String   @default("WITH FREEDOM")
  heroDescription        String   @default("Premium self drive cars, chauffeur services, luxury villas and curated Rajasthan travel experiences. Built specifically for elite global explorers.")
  heroBgImage            String   @default("https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?ixlib=rb-4.0.3&auto=format&fit=crop&w=2500&q=80")
  heroVideoUrl           String   @default("https://assets.mixkit.co/videos/preview/mixkit-luxury-car-parked-at-night-42289-large.mp4")
  seamlessBadge          String   @default("Discover the Mewar Heritage")
  seamlessTitle          String   @default("SEAMLESS")
  seamlessTitleHighlight String   @default("EXPERIENCES")
  seamlessDescription    String   @default("Navigate through our curated premium transportation lists and elite private escapes.")
  vehiclesBadge          String   @default("Real Automotive Collection")
  vehiclesTitle          String   @default("VEHICLE")
  vehiclesTitleHighlight String   @default("COLLECTION")
  vehiclesDescription    String   @default("Select key luxury automotive segments vetting senior brand names (Maruti Suzuki, Hyundai, Kia, Mahindra, Tata).")
  villasBadge            String   @default("Royal Residency Alliance")
  villasTitle            String   @default("VILLAS")
  villasTitleHighlight   String   @default("& CAR BUNDLES")
  villasDescription      String   @default("Five-star private villas paired directly with vetted SUVs in a single unified concierge booking.")
  toursTitle             String   @default("PREMIUM TOUR")
  toursTitleHighlight    String   @default("EXPERIENCES")
  toursDescription       String   @default("Skip lines directly. Access private expert guided itineraries covering historical temples and Mewar fortresses.")
  blogsBadge             String   @default("GoRidez Editorial Journal")
  blogsTitle             String   @default("FEATURED")
  blogsTitleHighlight    String   @default("STORIES")
  selfDriveImage         String   @default("https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?auto=format&fit=crop&w=1000&q=80")
  chauffeurImage         String   @default("https://images.unsplash.com/photo-1541899481282-d53bffe3c35d?auto=format&fit=crop&w=1000&q=80")
  airportTransferImage   String   @default("https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=1000&q=80")
  updatedAt              DateTime @updatedAt
}

model SiteSettings {
  id                String   @id @default("singleton")
  logoRidez         String   @default("/logo-ridez.png")
  logoFull          String   @default("/logo-full.png")
  favicon           String   @default("/favicon.ico")
  copyrightText     String   @default("© GoRidez. All rights reserved.")
  razorpayKeyId     String   @default("rzp_test_mockkey123")
  razorpayKeySecret String   @default("mocksecret123")
  taxiExclusions    String   @default("Toll Tax and Parking charges are not included in the above fare.\nState Tax (if applicable crossing borders) is extra.\nAny extra km or hours driven beyond the package limit will be charged additionally.")
  taxiTerms         String   @default("A/C will be switched off in hilly areas.\nNight allowance applies if the driver drives between 10 PM and 6 AM.\nKilometers are calculated from garage to garage.")
  updatedAt         DateTime @updatedAt
}
